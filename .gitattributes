# Ensure shell scripts always use LF line endings
*.sh text eol=lf
bin/* text eol=lf
py/bin/* text eol=lf

# Auto detect text files and normalize to LF
* text=auto eol=lf

# Ensure Windows batch files use CRLF if any exist
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
